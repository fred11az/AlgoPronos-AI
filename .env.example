# Football API (api-football.com / rapidapi)
# Get your key at https://www.api-football.com or https://rapidapi.com/api-sports/api/api-football
# Without this key, mock data will be used for development
FOOTBALL_API_KEY=your_football_api_key

# Football-Data.org API (FREE - recommended)
# Get your free key at https://www.football-data.org/client/register
# Free tier: 10 requests/minute, current season data
FOOTBALL_DATA_API_KEY=your_football_data_api_key
