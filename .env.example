# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Redis Cache (Upstash — STRONGLY RECOMMENDED for <15s generation guarantee)
# Free tier: 10 000 req/day — https://console.upstash.com/
# Without Redis, the app falls back to Supabase-only caching (still works but slower)
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AI APIs
# Claude Haiku (primary AI for analysis engine — REQUIRED)
ANTHROPIC_API_KEY=sk-ant-xxxx

# Groq (FREE alternative for simple tasks - OPTIONAL)
# Get free key: https://console.groq.com/
GROQ_API_KEY=gsk_xxxx

# Football API (optional - improves match coverage)
# Get key: https://www.api-football.com/
FOOTBALL_API_KEY=

# Resend (email transactionnel - REQUIRED)
# Get key: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=AlgoPronos AI <no-reply@mail.algopronos.com>

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AlgoPronos AI

# IMPORTANT: SITE_URL must be the production domain (https://algopronos.ai or https://algopronos.com).
# DO NOT set this to your Vercel preview URL — it is used for email redirect links and
# auth callbacks. If wrong, email confirmation links will point to *.vercel.app instead
# of your real domain.
SITE_URL=https://algopronos.com

# Admin (comma-separated emails — REQUIRED for admin section to work)
# Example: ADMIN_EMAILS=you@example.com,partner@example.com
# If not set, all admin routes will return 403 Forbidden.
ADMIN_EMAILS=admin@algopronos.ai

# WhatsApp Business (Meta Cloud API — OPTIONAL)
# Setup: https://developers.facebook.com → WhatsApp Business API
# Templates à créer dans Meta Business Suite (langue: fr)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_TICKET=ticket_result
WHATSAPP_TEMPLATE_ACTIVATION=account_activated

# 1xBet Affiliate
NEXT_PUBLIC_1XBET_PROMO_CODE=AlgoPronos
NEXT_PUBLIC_1XBET_AFFILIATE_URL=https://refpa14435.com/L?tag=d_5346138m_1599c_&site=5346138&ad=1599

# SEO — IndexNow (instant indexing on Bing, Yandex, etc.)
# 1. Generate a key at https://www.indexnow.org/faq
# 2. Set INDEXNOW_KEY=<your-key> here
# 3. Create public/<your-key>.txt containing only the key value
# 4. Pages are auto-submitted to IndexNow after each pronostic generation
INDEXNOW_KEY=
